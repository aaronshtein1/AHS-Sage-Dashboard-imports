# ==============================================================================
# ADP-to-Intacct Payroll Automation - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (for Next.js dashboard)
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/sage_fpa"

# ==============================================================================
# ADP CREDENTIALS (REQUIRED)
# ==============================================================================
# Your ADP Workforce Now login credentials

# ADP username (typically your email or employee ID)
ADP_USERNAME="your-adp-username"

# ADP password
ADP_PASSWORD="your-adp-password"

# ADP login URL (your company's ADP portal)
ADP_LOGIN_URL="https://workforcenow.adp.com/"

# ==============================================================================
# SAGE INTACCT CREDENTIALS (REQUIRED)
# ==============================================================================

# Intacct company ID (shown on login page)
INTACCT_COMPANY_ID="your-company-id"

# Intacct user ID
INTACCT_USER_ID="your-user-id"

# Intacct password
INTACCT_PASSWORD="your-intacct-password"

# Intacct browser login URL
INTACCT_LOGIN_URL="https://www.intacct.com/ia/acct/login.phtml"

# ------------------------------------------------------------------------------
# Sage Intacct Web Services API (Optional - for API integration)
# ------------------------------------------------------------------------------
# Get these from your Intacct Web Services subscription
INTACCT_SENDER_ID="your-sender-id"
INTACCT_SENDER_PASSWORD="your-sender-password"
INTACCT_USER_PASSWORD="your-user-password"
INTACCT_ENDPOINT="https://api.intacct.com/ia/xml/xmlgw.phtml"

# ------------------------------------------------------------------------------
# Encryption & Security
# ------------------------------------------------------------------------------
# Encryption key for storing credentials (generate with: openssl rand -base64 32)
ENCRYPTION_KEY="your-32-byte-encryption-key-here"

# ------------------------------------------------------------------------------
# Optional: OpenAI for AI features
# ------------------------------------------------------------------------------
OPENAI_API_KEY=""

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==============================================================================
# AUTOMATION SETTINGS
# ==============================================================================

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL="INFO"

# Enable file logging (true/false)
LOG_TO_FILE="true"

# ------------------------------------------------------------------------------
# Screenshot Configuration
# ------------------------------------------------------------------------------
# Enable screenshot capture during automation (true/false)
SCREENSHOTS_ENABLED="true"

# ------------------------------------------------------------------------------
# Dry Run Mode
# ------------------------------------------------------------------------------
# Enable dry-run mode (downloads from ADP but does NOT upload to Intacct)
# Set to "true" for testing or previewing the workflow
DRY_RUN="false"

# ------------------------------------------------------------------------------
# Browser Automation Configuration
# ------------------------------------------------------------------------------
# Run browser in headless mode (true/false)
# Set to false for debugging to see the browser
HEADLESS="false"

# Browser viewport dimensions
VIEWPORT_WIDTH="1920"
VIEWPORT_HEIGHT="1080"

# Page load timeout in milliseconds
PAGE_TIMEOUT="60000"

# Element interaction timeout in milliseconds
ELEMENT_TIMEOUT="30000"

# Download timeout in milliseconds
DOWNLOAD_TIMEOUT="120000"

# ------------------------------------------------------------------------------
# Retry Configuration
# ------------------------------------------------------------------------------
# Maximum retry attempts for failed operations
MAX_RETRIES="3"

# Base delay for exponential backoff (milliseconds)
RETRY_BASE_DELAY="1000"

# Maximum delay cap (milliseconds)
RETRY_MAX_DELAY="30000"

# ------------------------------------------------------------------------------
# MFA Configuration
# ------------------------------------------------------------------------------
# Timeout for MFA completion (milliseconds)
# Increase if you need more time to complete MFA
MFA_TIMEOUT="120000"

# ------------------------------------------------------------------------------
# File Paths (Optional - defaults provided)
# ------------------------------------------------------------------------------
# Download directory for ADP files
# DOWNLOAD_DIR="./downloads/payroll-gl"

# Export directory for Intacct-ready files
# EXPORT_DIR="./exports/intacct-ready"

# Screenshot directory
# SCREENSHOT_DIR="./screenshots"

# Log file directory
# LOG_DIR="./logs"

# State database path
# STATE_DB_PATH="./data/payroll-state.db"

# ------------------------------------------------------------------------------
# Mapping Configuration (Optional)
# ------------------------------------------------------------------------------
# Path to account mapping file
# ACCOUNT_MAPPING_PATH="./config/account-mapping.json"

# Path to department mapping file
# DEPARTMENT_MAPPING_PATH="./config/department-mapping.json"

# ------------------------------------------------------------------------------
# Notification Configuration (Optional)
# ------------------------------------------------------------------------------
# Email notifications for processing results
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="notifications@example.com"
# SMTP_PASSWORD="your-smtp-password"
# NOTIFICATION_EMAIL="finance-team@example.com"

# Slack webhook for notifications
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"
