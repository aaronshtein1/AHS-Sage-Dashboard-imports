# ==================== DATABASE ====================
DATABASE_URL="postgresql://openledger:openledger_dev_password@localhost:5432/openledger"

# ==================== AUTH ====================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="1d"

# ==================== ENCRYPTION ====================
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="your-32-byte-encryption-key-here"

# ==================== PLAID (WS4) ====================
PLAID_CLIENT_ID="your-plaid-client-id"
PLAID_SECRET="your-plaid-sandbox-secret"
PLAID_ENV="sandbox"

# ==================== APPLICATION ====================
NEXT_PUBLIC_API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3020"
BACKEND_PORT=3001

# ==================== LEGACY INTACCT (optional) ====================
INTACCT_SENDER_ID=""
INTACCT_SENDER_PASSWORD=""
INTACCT_COMPANY_ID=""
INTACCT_USER_ID=""
INTACCT_USER_PASSWORD=""
INTACCT_ENDPOINT="https://api.intacct.com/ia/xml/xmlgw.phtml"
