generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== SETTINGS ====================
model Settings {
  id                    String   @id @default("default")
  intacctCompanyId      String?
  intacctUserId         String?
  intacctUserPassword   String?  // Encrypted
  intacctSenderId       String?
  intacctSenderPassword String?  // Encrypted
  intacctEndpoint       String   @default("https://api.intacct.com/ia/xml/xmlgw.phtml")
  intacctSessionId      String?
  intacctSessionExpiry  DateTime?
  defaultLocationId     String?
  fiscalYearStartMonth  Int      @default(1)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ==================== HEALTHCARE ====================
model Location {
  id             String   @id @default(cuid())
  intacctId      String   @unique // Maps to LOCATIONID in Intacct
  name           String
  type           String?  // clinic, hospital, office
  address        String?
  isActive       Boolean  @default(true)
  metadata       Json?

  headcountPlans HeadcountPlan[]
  budgetItems    BudgetLineItem[]

  @@index([intacctId])
}

model Department {
  id          String   @id @default(cuid())
  intacctId   String   @unique // Maps to DEPARTMENTID in Intacct
  name        String
  parentId    String?
  isActive    Boolean  @default(true)

  @@index([intacctId])
}

model PayerContract {
  id                String    @id @default(cuid())
  payerName         String
  contractName      String
  effectiveDate     DateTime
  expirationDate    DateTime?
  reimbursementType String    // fee-for-service, capitation, value-based
  medicarePercent   Float?    // e.g., 120 = 120% of Medicare rates
  avgReimbursement  Float?    // Average $ per visit
  terms             Json?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([payerName, contractName])
}

// ==================== CHART OF ACCOUNTS ====================
model GLAccount {
  id              String   @id @default(cuid())
  intacctId       String   @unique // ACCOUNTNO in Intacct
  title           String
  accountType     String   // incomestatement, balancesheet
  normalBalance   String   // debit, credit
  category        String   // revenue, expense, asset, liability, equity
  subcategory     String?  // operating-revenue, cogs, operating-expense, etc.
  isActive        Boolean  @default(true)
  parentId        String?
  displayOrder    Int      @default(0)

  balances        GLBalance[]
  budgetItems     BudgetLineItem[]

  @@index([intacctId])
  @@index([accountType, category])
}

model GLBalance {
  id              String   @id @default(cuid())
  accountId       String
  account         GLAccount @relation(fields: [accountId], references: [id])
  locationId      String?
  departmentId    String?
  period          String   // YYYY-MM format
  openingBalance  Float    @default(0)
  debitAmount     Float    @default(0)
  creditAmount    Float    @default(0)
  netChange       Float    @default(0)
  endingBalance   Float    @default(0)
  fetchedAt       DateTime @default(now())

  @@unique([accountId, locationId, departmentId, period])
  @@index([period])
  @@index([accountId, period])
}

// ==================== WORKFORCE ====================
model Position {
  id               String   @id @default(cuid())
  title            String
  department       String   // clinical, administrative, billing
  category         String   // physician, np, ma, rn, front-desk, billing, manager, admin
  salaryMin        Float
  salaryMax        Float
  salaryMid        Float
  benefitsPercent  Float    @default(18)
  payrollTaxPercent Float   @default(8)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  headcountPlans   HeadcountPlan[]

  @@unique([title, department])
}

model HeadcountPlan {
  id             String    @id @default(cuid())
  positionId     String
  position       Position  @relation(fields: [positionId], references: [id])
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  budgetId       String
  budget         Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  period         String    // YYYY-MM format
  budgetedFTE    Float
  actualFTE      Float?
  avgSalary      Float
  notes          String?

  @@unique([positionId, locationId, budgetId, period])
  @@index([budgetId, period])
}

// ==================== PLANNING ====================
model Budget {
  id             String   @id @default(cuid())
  name           String
  fiscalYear     Int
  version        Int      @default(1)
  status         String   @default("draft") // draft, active, locked
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lineItems      BudgetLineItem[]
  headcountPlans HeadcountPlan[]
  scenarios      Scenario[]

  @@unique([name, fiscalYear, version])
}

model BudgetLineItem {
  id             String    @id @default(cuid())
  budgetId       String
  budget         Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId      String
  account        GLAccount @relation(fields: [accountId], references: [id])
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  departmentId   String?
  period         String    // YYYY-MM format
  amount         Float
  notes          String?
  drivers        Json?     // Driver-based inputs (volume, rate, etc.)

  @@unique([budgetId, accountId, locationId, departmentId, period])
  @@index([budgetId, period])
}

model Forecast {
  id             String   @id @default(cuid())
  name           String
  type           String   // rolling-12, annual, custom
  baselineType   String   // budget, actuals, hybrid
  startPeriod    String   // YYYY-MM
  endPeriod      String   // YYYY-MM
  asOfDate       DateTime
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lineItems      ForecastLineItem[]
}

model ForecastLineItem {
  id             String   @id @default(cuid())
  forecastId     String
  forecast       Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)
  accountId      String
  locationId     String?
  departmentId   String?
  period         String
  amount         Float
  method         String   // manual, trend, driver, seasonal
  confidence     Float?   // 0-1 confidence score
  notes          String?

  @@unique([forecastId, accountId, locationId, departmentId, period])
  @@index([forecastId, period])
}

model Scenario {
  id             String   @id @default(cuid())
  name           String
  description    String?
  baseBudgetId   String
  baseBudget     Budget   @relation(fields: [baseBudgetId], references: [id])
  assumptions    Json     // Changed drivers/assumptions
  results        Json?    // Calculated scenario results (cached)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==================== CACHE ====================
model CachedData {
  id             String   @id @default(cuid())
  dataType       String   // accounts, balances, transactions, employees
  periodKey      String   // YYYY-MM or "all"
  dimensionKey   String?  // location:001, dept:sales
  data           Json
  fetchedAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([dataType, periodKey, dimensionKey])
  @@index([dataType, expiresAt])
}

// ==================== DRIVER TEMPLATES ====================
model DriverTemplate {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  driverType     String   // patient-volume, headcount, revenue-per-unit
  formula        String   // JSON formula definition
  defaultInputs  Json?    // Default input values
  accountMappings Json?   // Which accounts this driver affects
  createdAt      DateTime @default(now())
}
